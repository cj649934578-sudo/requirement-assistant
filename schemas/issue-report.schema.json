{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "issue report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "summary", "issues", "pending_confirmations"],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "objects"],
      "properties": {
        "task": {"type": "string", "minLength": 1},
        "objects": {"type": "array", "items": {"type": "string"}}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["high", "medium", "low"],
      "properties": {
        "high": {"type": "integer"},
        "medium": {"type": "integer"},
        "low": {"type": "integer"}
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "severity", "title", "description", "why_it_matters"],
        "properties": {
          "type": {"type": "string", "enum": ["missing", "conflict", "ambiguous", "coverage-gap"]},
          "severity": {"type": "string", "enum": ["high", "medium", "low"]},
          "title": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "why_it_matters": {"type": "string", "minLength": 1},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "suggestion": {"type": "string"},
          "impacted_objects": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "pending_confirmations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "owner_hint"],
        "properties": {
          "question": {"type": "string", "minLength": 1},
          "owner_hint": {"type": "string", "minLength": 1},
          "suggested_options": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
